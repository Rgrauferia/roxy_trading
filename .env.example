# Roxy local environment template. Copy values into your local .env; never commit real secrets.

# Alpaca read-only/paper integration
# Leave these empty until you paste real paper credentials. Template values such as
# TU_KEY_PAPER/TU_SECRET_PAPER are detected as placeholders and blocked from live probes.
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Legacy alias also accepted by Roxy: ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex
# Optional server-side stock stream bridge. Run tools/roxy_stock_stream_bridge.py
# as a separate service. Do not put keys in frontend code.
ROXY_STOCK_BRIDGE_URL=
ROXY_STOCK_STREAM_URL=
ROXY_STOCK_SNAPSHOT_URL=
ROXY_STOCK_ALPACA_STREAM=1
# Comma-separated exact browser origins. Wildcard is rejected.
ROXY_STOCK_STREAM_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
ROXY_STOCK_BRIDGE_HOST=127.0.0.1
ROXY_STOCK_BRIDGE_TRUSTED_PROXIES=127.0.0.1

# Optional archival destinations. Local verified storage is used by default so
# a disconnected external volume cannot block the watchdog.
ROXY_OUTPUT_ARCHIVE_DIR=
ROXY_RUNTIME_BACKUP_TARGET_DIR=
ROXY_EXTERNAL_DISK_PATH=
# Optional learning sources use the OS path separator (`:` on macOS/Linux).
ROXY_VIDEO_SOURCES=
ROXY_VIDEO_ARCHIVE_DIR=
ROXY_ALPACA_PAPER_AUTOTRADE=false
ROXY_AUTOPILOT_CODE_WRITE=0

# Global live broker execution kill switch. Keep disabled unless a reviewed adapter explicitly supports it.
ROXY_ENABLE_LIVE_BROKER_EXECUTION=0

# Roxy login providers
# Google OAuth callback/authorized redirect URI:
# https://roxy-trading.onrender.com/
ROXY_PUBLIC_URL=https://roxy-trading.onrender.com
ROXY_GOOGLE_CLIENT_ID=
ROXY_GOOGLE_CLIENT_SECRET=

# Apple Sign In requires an Apple Developer Services ID plus a private key.
# Return URL / redirect URI:
# https://roxy-trading.onrender.com/
ROXY_APPLE_CLIENT_ID=
ROXY_APPLE_TEAM_ID=
ROXY_APPLE_KEY_ID=
# Paste the full PEM key in Render as a secret. Locally, quote it and use \n for line breaks.
ROXY_APPLE_PRIVATE_KEY=

# ElevenLabs Roxy Trading voice/chat assistant
# Keep ELEVENLABS_API_KEY server-side only. Never paste it into frontend code.
ELEVENLABS_AGENT_ID=agent_6101kwchebzdf91rfk9757wq0mk4
ELEVENLABS_API_KEY=
# Persisted auth circuit: avoids repeating a rejected key across rerenders/restarts.
ROXY_ELEVENLABS_AUTH_RETRY_SECONDS=21600

# Canonical local voice/state-sync service. Keep the loopback bind unless a
# reviewed HTTPS reverse proxy is in place. Remote access requires all of:
# VOICE_API_KEY, an explicit ROXY_STATE_SYNC_USERS allowlist, and HTTPS/TLS.
VOICE_API_KEY=
ROXY_STATE_SYNC_USERS=
ROXY_VOICE_BIND_HOST=127.0.0.1
ROXY_VOICE_PORT=8010
ROXY_VOICE_PUBLIC_BASE_URL=
ROXY_VOICE_TLS_TERMINATED=false

# Broker/platform credential placeholders for preview routing and vault status
CRYPTO_COM_API_KEY=
CRYPTO_COM_API_SECRET=
# Preferred Crypto.com Exchange aliases used by Roxy's external source connector.
# Public ticker/candle data does not require private keys; keep private keys server-side only.
ROXY_CRYPTOCOM_API_KEY=
ROXY_CRYPTOCOM_API_SECRET=
ROXY_CRYPTOCOM_BASE_URL=https://api.crypto.com/exchange/v1
ROXY_EXTERNAL_CONFIRMATION_ENABLED=true
ROXY_EXTERNAL_CONFIRMATION_REMOTE=
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=
SCHWAB_ACCESS_TOKEN=
SCHWAB_ACCOUNT_HASH=
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_ACCESS_TOKEN=
WEBULL_ACCOUNT_ID=

# Robinhood is strictly preview-only in Roxy. These names are placeholders for status/vault only.
ROBINHOOD_USERNAME=
ROBINHOOD_DEVICE_TOKEN=
ROBINHOOD_ACCOUNT_ID=

# Optional premium data/alert integrations
POLYGON_API_KEY=
POLYGON_API_TOKEN=
ROXY_FINVIZ_EXPORT_URL=
ROXY_FINVIZ_AUTH_TOKEN=
TRADIER_ACCESS_TOKEN=
DISCORD_WEBHOOK_URL=
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
WEBHOOK_URL=
TRADINGVIEW_WEBHOOK_SECRET=
TRADINGVIEW_PUBLIC_WEBHOOK_URL=
ROXY_TRADINGVIEW_WIDGET_ENABLED=true
ROXY_TRADINGVIEW_LIBRARY_URL=
SMTP_HOST=
ALERT_EMAIL_TO=
