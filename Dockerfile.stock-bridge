FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    ROXY_STOCK_ALPACA_STREAM=1

COPY requirements.txt ./
RUN python -m pip install --upgrade pip \
    && pip install -r requirements.txt

COPY . /app

EXPOSE 8765

CMD ["sh", "-c", "uvicorn tools.roxy_stock_stream_bridge:app --host 0.0.0.0 --port ${PORT:-8765}"]
