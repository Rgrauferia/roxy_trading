FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    ROXY_STOCK_ALPACA_STREAM=1

COPY requirements.stock-bridge.txt ./
RUN python -m pip install --upgrade pip \
    && pip install -r requirements.stock-bridge.txt

COPY tools ./tools

EXPOSE 8765

CMD ["python", "-m", "tools.roxy_stock_stream_bridge"]
